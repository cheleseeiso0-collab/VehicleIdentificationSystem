<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.vehicleidentificationsystem.controller.LoginController"
           stylesheets="@css/styles.css"
           styleClass="login-root-bg">
    <VBox alignment="CENTER" maxWidth="400" prefWidth="380" spacing="15" styleClass="login-card">

        <ImageView fitWidth="280" preserveRatio="true">
            <image>
                <Image url="@images/vehicle.jpeg" />
            </image>
            <effect>
                <DropShadow color="1565C0" radius="20" />
            </effect>
        </ImageView>

        <Text styleClass="login-title-text" text="Vehicle Identification System" />

        <Separator />

        <Label styleClass="input-label" text="USERNAME" />
        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field">
            <effect>
                <DropShadow color="gray" radius="5" />
            </effect>
        </TextField>

        <Label styleClass="input-label" text="PASSWORD" />
        <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field">
            <effect>
                <DropShadow color="gray" radius="5" />
            </effect>
        </PasswordField>

        <Label fx:id="statusLabel" styleClass="error-label" />

        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-button" text="SIGN IN">
            <effect>
                <InnerShadow color="darkblue" radius="10" />
            </effect>
        </Button>
    </VBox>
</StackPane>