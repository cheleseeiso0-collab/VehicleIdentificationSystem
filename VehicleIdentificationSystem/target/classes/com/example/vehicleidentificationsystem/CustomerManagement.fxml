<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.vehicleidentificationsystem.controller.CustomerController">
    <VBox stylesheets="@css/styles.css" styleClass="content-pane" spacing="15">

        <Text text="Customer Module" styleClass="page-title"/>
        <Text text="Manage vehicle owners &amp; their queries" styleClass="page-subtitle"/>

        <TableView fx:id="customerTable" styleClass="table-view" prefHeight="200">
            <columns>
                <TableColumn text="ID" prefWidth="50"/>
                <TableColumn text="Name" prefWidth="150"/>
                <TableColumn text="Address" prefWidth="200"/>
                <TableColumn text="Phone" prefWidth="120"/>
                <TableColumn text="Email" prefWidth="180"/>
            </columns>
        </TableView>

        <!-- ========== ADD CUSTOMER FORM ========== -->
        <TitledPane text="Add Customer" expanded="false">
            <GridPane hgap="10" vgap="8" styleClass="form-grid">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Name" styleClass="input-label"/>
                    <TextField fx:id="addNameField" promptText="Full Name" styleClass="text-field"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Address" styleClass="input-label"/>
                    <TextField fx:id="addAddressField" promptText="Address" styleClass="text-field"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Phone" styleClass="input-label"/>
                    <TextField fx:id="addPhoneField" promptText="Phone" styleClass="text-field"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Email" styleClass="input-label"/>
                    <TextField fx:id="addEmailField" promptText="Email" styleClass="text-field"/>
                </VBox>

                <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                    <Button text="Add Customer" styleClass="primary-button" onAction="#handleAddCustomer"/>
                    <Button text="Cancel" styleClass="secondary-button" onAction="#handleCancelAddCustomer"/>
                </HBox>
            </GridPane>
        </TitledPane>

        <!-- ========== EDIT SELECTED CUSTOMER ========== -->
        <TitledPane text="Edit Selected Customer" expanded="false">
            <GridPane hgap="10" vgap="8" styleClass="form-grid">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Name" styleClass="input-label"/>
                    <TextField fx:id="editNameField" styleClass="text-field"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Address" styleClass="input-label"/>
                    <TextField fx:id="editAddressField" styleClass="text-field"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Phone" styleClass="input-label"/>
                    <TextField fx:id="editPhoneField" styleClass="text-field"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Email" styleClass="input-label"/>
                    <TextField fx:id="editEmailField" styleClass="text-field"/>
                </VBox>

                <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                    <Button text="Update Customer" styleClass="primary-button" onAction="#handleUpdateCustomer"/>
                    <Button text="Cancel" styleClass="secondary-button" onAction="#handleCancelEditCustomer"/>
                </HBox>
            </GridPane>
        </TitledPane>

        <Button text="Delete Selected Customer" styleClass="danger-button" onAction="#handleDeleteCustomer"/>

        <Separator/>

        <!-- ========== SEND INQUIRY ========== -->
        <Text text="Send Inquiry About your Vehicle" styleClass="section-header"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints percentWidth="30"/>
                <ColumnConstraints percentWidth="70"/>
            </columnConstraints>

            <Label text="Customer Name" styleClass="input-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="inquiryCustomerName" promptText="Enter Name" styleClass="text-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Vehicle ID" styleClass="input-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="inquiryVehicleId" promptText="Enter vehicle ID" styleClass="text-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Message" styleClass="input-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextArea fx:id="inquiryText" promptText="Write your inquiry…" styleClass="text-field"
                      prefRowCount="3" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <Button text="Send Inquiry" styleClass="primary-button" onAction="#handleSendInquiry"/>
                <Button text="Cancel" styleClass="secondary-button" onAction="#handleCancelSendInquiry"/>
            </HBox>
        </GridPane>

        <Separator/>

        <Text text="Inquiries about Vehicles" styleClass="section-header"/>
        <TableView fx:id="inquiryTable" styleClass="table-view" prefHeight="200">
            <columns>
                <TableColumn text="ID" prefWidth="50"/>
                <TableColumn text="Customer ID" prefWidth="80"/>
                <TableColumn text="Customer Name" prefWidth="120"/>
                <TableColumn text="Vehicle" prefWidth="80"/>
                <TableColumn text="Date" prefWidth="100"/>
                <TableColumn text="Message" prefWidth="200"/>
                <TableColumn text="Response" prefWidth="200"/>
            </columns>
        </TableView>
        <HBox spacing="10">
            <Button text="Respond to Selected" styleClass="secondary-button" onAction="#handleRespondInquiry"/>
            <Button text="Edit Inquiry" styleClass="secondary-button" onAction="#handleEditInquiry"/>
            <Button text="Delete Inquiry" styleClass="danger-button" onAction="#handleDeleteInquiry"/>
        </HBox>
    </VBox>
</ScrollPane>